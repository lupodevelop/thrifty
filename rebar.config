{erl_opts, [debug_info]}.
{deps, []}.

{plugins, [rebar3_hex]}.

{package, [
  {name, <<"thrifty">>},
  {version, "1.0.0"},
  {licenses, ["Apache-2.0"]},
  {links, [{"GitHub", "https://github.com/youruser/thrifty"}]},
  {files, ["src", "gleam.toml", "README.md", "LICENSE"]}
]}.

%% Documentation provider for Hex (recommended). Update the source_url to your repo.
{project_plugins, [rebar3_ex_doc]}.

{hex, [{doc, ex_doc}]}.

{ex_doc, [
  {source_url, <<"https://github.com/youruser/thrifty">>},
  {extras, [<<"README.md">>, <<"LICENSE">>]},
  {main, <<"readme">>}
]}.
